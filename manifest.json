{
  "manifest_version": 3,
  "name": "AI Translator & Grammar Check",
  "version": "1.1.0",
  "description": "Translate text and check grammar using AI",
  "author": "Hieu Tran H",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.mymemory.translated.net/*",
    "https://translate.googleapis.com/*",
    "https://api.languagetool.org/*"
  ],
  "action": {
    "default_popup": "pages/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "24": "assets/icons/icon24.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "24": "assets/icons/icon24.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/icons/*.png", "pages/settings/settings.html", "pages/history/history.html", "pages/flashcards/flashcards.html", "pages/flashcards/study.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "commands": {
    "translate-selection": {
      "suggested_key": {
        "default": "Alt+Shift+T",
        "windows": "Alt+Shift+T",
        "mac": "Alt+Shift+T",
        "chromeos": "Alt+Shift+T",
        "linux": "Alt+Shift+T"
      },
      "description": "Translate selected text"
    },
    "check-grammar": {
      "suggested_key": {
        "default": "Alt+Shift+G",
        "windows": "Alt+Shift+G",
        "mac": "Alt+Shift+G",
        "chromeos": "Alt+Shift+G",
        "linux": "Alt+Shift+G"
      },
      "description": "Check grammar of selected text"
    },
    "open-settings": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "windows": "Alt+Shift+S",
        "mac": "Alt+Shift+S",
        "chromeos": "Alt+Shift+S",
        "linux": "Alt+Shift+S"
      },
      "description": "Open AI Translator settings"
    },
    "open-flashcards": {
      "suggested_key": {
        "default": "Alt+Shift+F",
        "windows": "Alt+Shift+F",
        "mac": "Alt+Shift+F",
        "chromeos": "Alt+Shift+F",
        "linux": "Alt+Shift+F"
      },
      "description": "Open My Flashcards"
    },
    "open-history": {
      "description": "Open Translation History"
    }
  }
}
